#!/bin/sh
#设置语言
export LANG=zh_CN.UTF-8
#开始处理压缩代码
source ./web
#使用七牛cdn减速服务
sed -i "s/\/static/http:\/\/7xsbbu.com1.z0.glb.clouddn.com\/static/g" ./*.html 
git add --all .
#判断是否写commit
if [ -n "$f1" ];then
	git commit -S -m "$(date -d @$timestamp) $1"
else
	git commit -S -m "$(date -d @$timestamp)"
fi
#检擦远程代码是否有更新
git pull
