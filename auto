file_array=(
	./index.html 
	./static/
	)
scp  -i ~/router -r ${file_array[@]} root@router:/web/
#scp -i ~/router -r ./index.html  ./static/ root@router:/web/
sed -i "s/http:\/\/7xsbbu.com1.z0.glb.clouddn.com\/static/\/static/g" ./*.html
