http://7u2f38.com5.z0.glb.clouddn.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css \
 | sed  "s/..\/fonts\//http:\/\/7u2f38.com5.z0.glb.clouddn.com\/ajax\/libs\/font-awesome\/4.7.0\/fonts\//g" \
 > ../../static/css/web.i.css
 cat ../css//boot.css >> ../../static/css/web.i.css
