#!/bin/sh
curl http://127.0.0.1:81/jquery.min.js > ../lib/js/jquery.min.js
curl http://7u2f38.com5.z0.glb.clouddn.com/ajax/libs/socket.io/2.0.4/socket.io.js  > ../../static/js/web.i.js
